# =========================================================================
# ACB Backend — Environment Configuration Example
# Copy this file to ".env" and fill in real values. Never commit ".env".
# =========================================================================

# =========================
# AI / Gemini
# =========================
GEMINI_API_KEY=your_gemini_api_key
MODEL_NAME=gemini-2.5-flash

# =========================
# Clerk (Authentication)
# =========================
CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Frontend (Vite) — same Clerk publishable key, exposed to client build
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key

# =========================
# Database (Neon Postgres)
# =========================
# Use the POOLED connection string for normal app runtime.
# Format: postgresql+psycopg://<user>:<password>@<pooler-host>/<db>?sslmode=require&channel_binding=require
# Note: role-level search_path=public must be set once via:
#   ALTER ROLE neondb_owner SET search_path TO public;
DATABASE_URL=postgresql+psycopg://neondb_owner:your_neon_password@ep-silent-sky-ax4wcpbn-pooler.c-4.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# =========================
# Workspace (local generated files — being migrated to object storage)
# =========================
WORKSPACE_DIR=/app/workspace
DOCKER_WORKSPACE_HOST_DIR=D:\codes\project\ACB\workspace

# =========================
# Object Storage (Cloudflare R2 — S3-compatible)
# Used for generated files instead of local disk, so they survive
# container restarts / redeploys / multi-instance scaling.
# =========================
STORAGE_ENDPOINT_URL=https://<your_account_id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your_access_key_id
STORAGE_SECRET_KEY=your_access_key
STORAGE_REGION=auto

# =========================
# Application
# =========================
APP_ENV=development
APP_VERSION=1.0.0

# =========================
# Server
# =========================
HOST=0.0.0.0
PORT=8000

# =========================
# Logging
# =========================
DEBUG=True
LOG_LEVEL=INFO

# =========================
# CORS / Frontend
# =========================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =========================
# Docker Sandbox (code execution containers)
# =========================
DOCKER_ENABLED=True
DOCKER_IMAGE=python:3.12-slim
DOCKER_CONTAINER_PREFIX=acb-agent
DOCKER_AUTO_REMOVE=True
DOCKER_WORKDIR=/workspace
DOCKER_NETWORK_DISABLED=False
DOCKER_MEMORY_LIMIT=512m
DOCKER_NANO_CPUS=1000000000

# =========================
# Memory / Retry / Validation (tune as needed)
# =========================
MEMORY_LIMIT=20
MAX_RETRIES=3
MAX_AI_FIX_ATTEMPTS=3
ENABLE_VALIDATION=True
